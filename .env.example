# Contact form (Resend)
# Get an API key at https://resend.com
RESEND_API_KEY=
CONTACT_TO_EMAIL=honsha@alpha-kanko.co.jp
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Google Analytics 4 (optional)
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# microCMS — 施工事例の管理画面
# 1. https://microcms.io でサービス作成
# 2. API「works」を作成（フィールドは下記）
# 3. ドメインと API キーを設定
# 4. Webhook: https://あなたのドメイン/api/revalidate?secret=（下の値）
#
# API fields (works):
# - title (テキスト)
# - slug (テキスト) 例: new-house-plumbing
# - category (セレクト)
#     新築給排水設備工事 / 給水・給湯配管工事 / 排水設備工事 / 水回りリフォーム / 給湯器交換工事
# - description (テキストエリア)
# - layout (セレクト) standard / beforeAfter / gallery
# - coverImage (画像)
# - gallery (画像・複数)
# - beforeImage (画像・任意)
# - afterImage (画像・任意)
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=

# On-demand revalidation secret (任意の長い文字列)
REVALIDATE_SECRET=
